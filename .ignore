# Whitelist: ignore everything, then un-ignore desired trees
*
!/*
!crates/
!crates/**
!docs/
!docs/**
!.jp/
!.jp/**
!.config/
!.config/**

# Then the exclusions (applied within the un-ignored trees)
.jp/conversations/
docs/.yarn/
docs/.vitepress/cache/
docs/.vitepress/dist/
docs/.pnp.*
docs/yarn.lock
**/target/**
.git/
/tmp
**/fixtures/
docs2/
